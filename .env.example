# 私有控制台访问口令。未设置时，本地开发默认不启用访问保护。
DASHBOARD_ACCESS_CODE=change-me

# 会话签名盐。部署时应使用随机长字符串。
DASHBOARD_SESSION_SECRET=change-me-random-session-secret

# Next 服务到 FastAPI 服务的内部请求令牌。部署时应使用随机长字符串。
AIOT_INTERNAL_API_TOKEN=change-me-random-internal-token

# 只有启用 HTTPS 时才设置为 true。IP 直连 HTTP 部署应保持 false 或不设置。
DASHBOARD_COOKIE_SECURE=false
