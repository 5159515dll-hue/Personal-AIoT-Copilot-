[Unit]
Description=AIoT Copilot MediaMTX RTSP/HLS service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/aiot-copilot
EnvironmentFile=/home/ubuntu/aiot-copilot/.dashboard-env
ExecStart=/usr/local/bin/mediamtx /home/ubuntu/aiot-copilot/infra/systemd/mediamtx.yml
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
